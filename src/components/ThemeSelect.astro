---
const labels = {
  light: 'Light',
  dark: 'Dark',
  auto: 'Auto',
}
const accessibleLabel = 'Select theme'
---

<vela-theme-select class="dux-menu" data-menu-kind="theme">
  <button class="dux-menu__trigger" type="button" aria-haspopup="menu" aria-expanded="false" aria-label={accessibleLabel}>
    <span class="dux-menu__icon" aria-hidden="true" data-theme-icon="auto">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M8 20h8M12 16v4"/></svg>
    </span>
    <span class="dux-menu__label" data-theme-label>{labels.auto}</span>
    <span class="dux-menu__caret" aria-hidden="true">▾</span>
  </button>
  <div class="dux-menu__panel" role="menu" aria-label={accessibleLabel}>
    <button type="button" role="menuitemradio" data-theme-choice="light" aria-checked="false">
      <span class="dux-menu__mark" aria-hidden="true"></span>
      <span>{labels.light}</span>
    </button>
    <button type="button" role="menuitemradio" data-theme-choice="dark" aria-checked="false">
      <span class="dux-menu__mark" aria-hidden="true"></span>
      <span>{labels.dark}</span>
    </button>
    <button type="button" role="menuitemradio" data-theme-choice="auto" aria-checked="true">
      <span class="dux-menu__mark" aria-hidden="true"></span>
      <span>{labels.auto}</span>
    </button>
  </div>
</vela-theme-select>

<script is:inline define:vars={{ labels }}>
  (() => {
    const storageKey = 'vela-theme';
    const parseTheme = (value) => (value === 'light' || value === 'dark' || value === 'auto' ? value : 'auto');
    const preferred = () => (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    const loadTheme = () => parseTheme(localStorage.getItem(storageKey) || 'auto');
    const storeTheme = (theme) => localStorage.setItem(storageKey, theme);
    const iconHTML = {
      light: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>',
      dark: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"/></svg>',
      auto: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M8 20h8M12 16v4"/></svg>',
    };
    const closeAll = () => {
      document.querySelectorAll('vela-theme-select[data-open="true"]').forEach((menu) => {
        menu.dataset.open = 'false';
        menu.querySelector('.dux-menu__trigger')?.setAttribute('aria-expanded', 'false');
      });
    };
    const applyTheme = (theme) => {
      const selected = parseTheme(theme);
      document.documentElement.dataset.theme = selected === 'auto' ? preferred() : selected;
      document.querySelectorAll('vela-theme-select').forEach((menu) => {
        menu.dataset.value = selected;
        const label = menu.querySelector('[data-theme-label]');
        if (label) label.textContent = labels[selected];
        const icon = menu.querySelector('[data-theme-icon]');
        if (icon) {
          icon.dataset.themeIcon = selected;
          icon.innerHTML = iconHTML[selected];
        }
        menu.querySelectorAll('[data-theme-choice]').forEach((item) => {
          item.setAttribute('aria-checked', item.dataset.themeChoice === selected ? 'true' : 'false');
        });
      });
    };
    class VelaThemeSelect extends HTMLElement {
      connectedCallback() {
        if (this.dataset.ready === 'true') return;
        this.dataset.ready = 'true';
        const trigger = this.querySelector('.dux-menu__trigger');
        trigger?.addEventListener('click', (event) => {
          event.stopPropagation();
          const willOpen = this.dataset.open !== 'true';
          closeAll();
          this.dataset.open = willOpen ? 'true' : 'false';
          trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });
        this.querySelectorAll('[data-theme-choice]').forEach((item) => {
          item.addEventListener('click', (event) => {
            event.stopPropagation();
            const theme = parseTheme(item.dataset.themeChoice);
            storeTheme(theme);
            applyTheme(theme);
            closeAll();
          });
        });
        applyTheme(loadTheme());
      }
    }
    if (!customElements.get('vela-theme-select')) customElements.define('vela-theme-select', VelaThemeSelect);
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      if (loadTheme() === 'auto') applyTheme('auto');
    });
    document.addEventListener('click', closeAll);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeAll();
    });
    applyTheme(loadTheme());
  })();
</script>
