---
import config from 'virtual:vela/config'
import velaStyles from 'virtual:vela/styles'
import { themeColorStyle } from '../utils/color'
import { alternateUrlForLocale, assetUrl, canonicalUrl, type VelaDocEntry, type VelaRouteContext } from '../utils/routes'

interface Props {
  entry: VelaDocEntry
  route: VelaRouteContext
  title: string
  description?: string
}

const { entry, route, title, description } = Astro.props
const meta = config.meta ?? {}
const image = withBase(entry.data.image || meta.image)
const imageAlt = entry.data.imageAlt || meta.imageAlt || title
const keywords = entry.data.keywords || meta.keywords
const favicon = withBase(config.favicon)
const theme = config.theme ?? {}
const themeColor = theme.light || theme.accent || meta.themeColor
const darkThemeColor = theme.dark || themeColor
const style = themeColorStyle(theme)
const canonical = canonicalUrl(Astro.url.pathname, Astro.site)
const alternates = Astro.site
  ? Object.entries(config.locales).map(([locale, item]) => ({
      lang: item.lang || locale,
      href: new URL(alternateUrlForLocale(route.slug, locale), Astro.site).toString(),
    }))
  : []

function withBase(value: string | undefined): string | undefined {
  if (!value) return undefined
  return assetUrl(value)
}
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content="Vela" />
<title>{title}</title>
{description && <meta name="description" content={description} />}
{keywords?.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
{favicon && <link rel="icon" href={favicon} />}
{canonical && <link rel="canonical" href={canonical} />}
{alternates.map((item) => (
  <link rel="alternate" hreflang={item.lang} href={item.href} />
))}
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
{canonical && <meta property="og:url" content={canonical} />}
{image && <meta property="og:image" content={image} />}
{image && <meta property="og:image:alt" content={imageAlt} />}
<meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
{meta.twitter && <meta name="twitter:site" content={meta.twitter} />}
{image && <meta name="twitter:image" content={image} />}
{imageAlt && <meta name="twitter:image:alt" content={imageAlt} />}
{themeColor && <meta name="theme-color" media="(prefers-color-scheme: light)" content={themeColor} />}
{darkThemeColor && <meta name="theme-color" media="(prefers-color-scheme: dark)" content={darkThemeColor} />}
{style && <style is:inline set:html={style} />}
<style is:inline set:html={velaStyles} />
