---
import config from 'virtual:vela/config'
import { hrefForLink, labelFor, type VelaLocaleContext } from '../utils/navigation'
import type { VelaDocEntry, VelaRouteContext } from '../utils/routes'

interface Props {
  entry: VelaDocEntry
  route: VelaRouteContext
}

const { entry, route } = Astro.props
const data = entry.data
const ctx: VelaLocaleContext = {
  base: import.meta.env.BASE_URL.replace(/\/$/, ''),
  currentPath: Astro.url.pathname,
  locale: route.locale,
  defaultLocale: config.defaultLocale,
  lang: route.lang,
}
const hero = config.home ?? {}
const frontmatterHero = data.hero ?? {}
const title = frontmatterHero.title || hero.title || data.title || config.title
const tagline = frontmatterHero.tagline || hero.tagline || config.description
const eyebrow = hero.eyebrow
const badge = hero.badge
const actions = frontmatterHero.actions?.length ? frontmatterHero.actions : hero.actions ?? []
const features = hero.features ?? []
const command = hero.command
const code = hero.code
---

<section class="vela-home-hero not-content">
  <div class="vela-home-hero__copy">
    {eyebrow && <p class="vela-home-hero__eyebrow">{eyebrow}</p>}
    {badge && <p class="vela-home-hero__badge">{badge}</p>}
    <h1 id="_top" set:html={title} />
    {tagline && <p class="vela-home-hero__tagline" set:html={tagline} />}
    {actions.length > 0 && (
      <div class="vela-home-hero__actions">
        {actions.map((action, index) => {
          const href = action.link || hrefForLink(action, ctx)
          const variant = action.variant || (index === 0 ? 'primary' : 'secondary')
          return <a class:list={['vela-home-btn', `vela-home-btn--${variant}`]} href={href}>{action.text || labelFor(action, ctx)}</a>
        })}
      </div>
    )}
  </div>
  {(features.length > 0 || command || code) && (
    <div class="vela-home-panel">
      {command && (
        <div class="vela-home-terminal">
          <span aria-hidden="true">$</span>
          <code>{command}</code>
        </div>
      )}
      {code && <pre><code>{code}</code></pre>}
      {features.length > 0 && (
        <div class="vela-home-features">
          {features.map((feature) => (
            <a href={feature.href || hrefForLink(feature, ctx)}>
              <strong>{labelFor(feature, ctx)}</strong>
              {feature.description && <span>{feature.description}</span>}
            </a>
          ))}
        </div>
      )}
    </div>
  )}
</section>
