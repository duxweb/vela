import type { VelaSidebarEntry } from '../utils/navigation'

interface Props {
  entries: VelaSidebarEntry[]
}

const { entries } = Astro.props
---

<nav id="vela-sidebar" class="vela-sidebar-nav" aria-label="Documentation">
  <SidebarTree entries={entries} />
</nav>
