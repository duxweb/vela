---
interface Props {
  target?: string;
}
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { target = `${base}/zh-cn/` } = Astro.props;
---
<script is:inline define:vars={{ target }}>
  (() => {
    const key = 'vela:language-redirected';
    const path = window.location.pathname;
    const normalizedBase = target.replace(/\/zh-cn\/$/, '') || '/';
    const isRoot = path === normalizedBase || path === normalizedBase + '/' || path === '/' || path === '';
    if (!isRoot || window.sessionStorage.getItem(key)) return;
    const languages =
      navigator.languages && navigator.languages.length
        ? navigator.languages
        : [navigator.language];
    const prefersChinese = languages.some((lang) => /^zh/i.test(lang || ''));
    if (!prefersChinese) return;
    window.sessionStorage.setItem(key, '1');
    window.location.replace(target);
  })();
</script>
