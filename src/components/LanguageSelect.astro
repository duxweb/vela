---
import config from 'virtual:vela/config'
import { alternateUrlForLocale, type VelaRouteContext } from '../utils/routes'

interface Props {
  route: VelaRouteContext
}

const { route } = Astro.props
const entries = Object.entries(config.locales)
const isMultilingual = entries.length > 1
const current = config.locales[route.locale]?.label ?? 'Language'
const options = entries.map(([code, locale]) => ({
  href: alternateUrlForLocale(route.slug, code),
  selected: code === route.locale,
  label: locale.label,
}))
const accessibleLabel = route.lang.toLowerCase().startsWith('zh') ? '选择语言' : 'Select language'
---

{isMultilingual && (
  <vela-lang-select class="dux-menu" data-menu-kind="language">
    <button class="dux-menu__trigger" type="button" aria-haspopup="menu" aria-expanded="false" aria-label={accessibleLabel}>
      <span class="dux-menu__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h9M9 3v2M11 5c-.7 3.9-2.8 6.9-6 9M6 9c1.2 2.1 3 3.9 5.3 5.2"/><path d="M13 21l5-11 5 11M15 17h6"/></svg>
      </span>
      <span class="dux-menu__label">{current}</span>
      <span class="dux-menu__caret" aria-hidden="true">
        <svg viewBox="0 0 20 20" fill="none">
          <path d="M5 7.5 10 12.5 15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </button>
    <div class="dux-menu__panel" role="menu" aria-label={accessibleLabel}>
      {options.map((option) => (
        <a href={option.href} role="menuitemradio" aria-checked={option.selected ? 'true' : 'false'}>
          <span class="dux-menu__mark" aria-hidden="true"></span>
          <span>{option.label}</span>
        </a>
      ))}
    </div>
  </vela-lang-select>
)}

<script is:inline>
  (() => {
    const closeAll = () => {
      document.querySelectorAll('vela-lang-select[data-open="true"]').forEach((menu) => {
        menu.dataset.open = 'false';
        menu.querySelector('.dux-menu__trigger')?.setAttribute('aria-expanded', 'false');
      });
    };
    class VelaLanguageSelect extends HTMLElement {
      connectedCallback() {
        if (this.dataset.ready === 'true') return;
        this.dataset.ready = 'true';
        const trigger = this.querySelector('.dux-menu__trigger');
        trigger?.addEventListener('click', (event) => {
          event.stopPropagation();
          const willOpen = this.dataset.open !== 'true';
          closeAll();
          this.dataset.open = willOpen ? 'true' : 'false';
          trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });
      }
    }
    if (!customElements.get('vela-lang-select')) customElements.define('vela-lang-select', VelaLanguageSelect);
    document.addEventListener('click', closeAll);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeAll();
    });
  })();
</script>
