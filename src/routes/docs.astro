---
import { getCollection, render } from 'astro:content'
import DocsLayout from '../layouts/DocsLayout.astro'
import { routePathFromEntry, currentRouteContext, entryPath, type VelaDocEntry } from '../utils/routes'

export async function getStaticPaths() {
  const entries = await getCollection('docs')
  return entries.map((entry) => ({
    params: {
      slug: routePathFromEntry(entry) || undefined,
    },
    props: {
      entry,
      entries,
    },
  }))
}

interface Props {
  entry: VelaDocEntry
  entries: VelaDocEntry[]
}

const { entry, entries } = Astro.props
const route = currentRouteContext(Astro.url.pathname)
const { Content, headings } = await render(entry)

const entryMap = new Map(entries.map((item) => [entryPath(item), item]))
---

<DocsLayout entry={entry} entries={entries} entryMap={entryMap} headings={headings} route={route}>
  <Content />
</DocsLayout>
